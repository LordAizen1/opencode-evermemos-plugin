# EverMemOS plugin configuration
# Copy this file to .env and fill in your values, or use evermemos.jsonc instead.
# See README for full configuration reference.

# EverMemOS server URL (default: http://localhost:8000)
EVERMEMOS_BASE_URL=http://localhost:1995

# Retrieval method: keyword | vector | hybrid | rrf (default: hybrid)
EVERMEMOS_RETRIEVE_METHOD=keyword

# Number of memories to recall per query (default: 5)
EVERMEMOS_RECALL_TOP_K=5

# Fetch and inject profile memories (default: true)
EVERMEMOS_INJECT_PROFILE_RECALL=true

# Max profile memories to inject (default: 3)
EVERMEMOS_PROFILE_RECALL_LIMIT=3

# Sender ID written to EverMemOS (default: opencode-user)
EVERMEMOS_SENDER_ID=opencode-user

# Timeout for recall requests in ms (default: 300)
EVERMEMOS_RECALL_TIMEOUT_MS=300

# Timeout for write requests in ms (default: 500)
EVERMEMOS_WRITE_TIMEOUT_MS=500

# Max characters per stored tool summary (default: 2048)
EVERMEMOS_TOOL_OUTPUT_MAX_CHARS=2048

# Optional: override path to evermemos.jsonc config file
# EVERMEMOS_CONFIG_PATH=~/.config/opencode/evermemos.jsonc

# Optional: override path to local memory store
# EVERMEMOS_LOCAL_STORE_PATH=~/.config/opencode/evermemos-local.json
